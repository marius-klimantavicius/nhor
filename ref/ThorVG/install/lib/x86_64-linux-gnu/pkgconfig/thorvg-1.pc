prefix=/home/marius/p/NHorvg3/ThorVG/install
includedir=${prefix}/include
libdir=${prefix}/lib/x86_64-linux-gnu

Name: libthorvg
Description: A Thor library for rendering vector graphics
Version: 1.0.0
Requires.private: libpng
Libs: -L${libdir} -lthorvg-1
Libs.private: -fopenmp -lpthread
Cflags: -I${includedir}/thorvg-1
